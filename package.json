{
  "name": "@rheactor/rheactor-query-builder",
  "version": "1.0.0",
  "description": "Rheactor Query Builder for SQLite.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf ./dist && tspc -p ./tsconfig.build.json && swc ./dist -d .",
    "typecheck": "tsc --noEmit",
    "oxfmt": "oxfmt --check ./src ./tests",
    "oxfmt:fix": "oxfmt --write ./src ./tests",
    "eslint": "eslint ./src ./tests",
    "eslint:fix": "eslint --fix ./src ./tests",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@rheactor/eslint-config-rheactor": "github:rheactor/eslint-config-rheactor",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint": "^10.4.0",
    "oxfmt": "^0.51.0",
    "rimraf": "^6.1.3",
    "ts-patch": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-transform-paths": "^4.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
